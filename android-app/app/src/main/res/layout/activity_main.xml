<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calc_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/calc_bg"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/calc_bg"
            app:title="@string/app_name"
            app:titleTextColor="@color/calc_display_text" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/calc_bg"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ── Display ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/currencyToggleGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:checkedButton="@id/btnJpy"
                app:singleSelection="true"
                app:selectionRequired="true">

                <Button
                    android:id="@+id/btnJpy"
                    android:layout_width="72dp"
                    android:layout_height="32dp"
                    android:text="¥ JPY"
                    android:textSize="11sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/btnUsd"
                    android:layout_width="72dp"
                    android:layout_height="32dp"
                    android:text="$ USD"
                    android:textSize="11sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:id="@+id/amountDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="52sp"
                android:textColor="@color/calc_display_text"
                android:gravity="end"
                android:maxLines="2"
                android:ellipsize="start"
                android:fontFamily="sans-serif-light"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/categoryDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="カテゴリなし"
                android:textSize="14sp"
                android:textColor="@color/calc_display_sub"
                android:gravity="end"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/calc_divider" />

        <!-- ── Category chips ── -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/categoryGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            app:chipSpacingHorizontal="6dp"
            app:chipSpacingVertical="4dp"
            app:singleSelection="true"
            app:selectionRequired="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/calc_divider" />

        <!-- ── Numpad ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- Row 1: C  ⌫  ± -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button android:id="@+id/btnClear"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="C" android:textSize="20sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_utility" />

                <Button android:id="@+id/btnBackspace"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="⌫" android:textSize="20sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_utility" />

                <Button android:id="@+id/btnSign"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="±" android:textSize="20sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_utility" />

            </LinearLayout>

            <!-- Row 2: 7  8  9 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button android:id="@+id/btn7"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="7" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

                <Button android:id="@+id/btn8"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="8" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

                <Button android:id="@+id/btn9"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="9" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

            </LinearLayout>

            <!-- Row 3: 4  5  6 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button android:id="@+id/btn4"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="4" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

                <Button android:id="@+id/btn5"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="5" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

                <Button android:id="@+id/btn6"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="6" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

            </LinearLayout>

            <!-- Row 4: 1  2  3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button android:id="@+id/btn1"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="1" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

                <Button android:id="@+id/btn2"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="2" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

                <Button android:id="@+id/btn3"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="3" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

            </LinearLayout>

            <!-- Row 5: .  0  送信 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button android:id="@+id/btnDecimal"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="." android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

                <Button android:id="@+id/btn0"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="0" android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_number" />

                <Button android:id="@+id/btnSend"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="送信" android:textSize="18sp"
                    style="@style/Widget.MaterialComponents.Button"
                    app:backgroundTint="@color/calc_btn_send" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
